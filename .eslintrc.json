{
  "env": {
    "browser": true,
    "es2021": true,
    "jest": true,
    "node": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": 2021,
    "sourceType": "script"
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "off",
    "semi": ["error", "always"],
    "quotes": ["warn", "single", { "avoidEscape": true }]
  },
  "ignorePatterns": [
    "node_modules/",
    "coverage/",
    "cypress/",
    "slick/",
    "scripts/script.js",
    "scripts/script1.js",
    "scripts/script-category.js",
    "scripts/script-product.js"
  ]
}
